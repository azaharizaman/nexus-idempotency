{
    "name": "nexus/idempotency",
    "description": "Domain-level idempotency: command deduplication and replay-safe results (Layer 1).",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.3"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Nexus\\Idempotency\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Nexus\\Idempotency\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
